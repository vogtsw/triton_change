{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triton-change.local/schemas/task.json",
  "title": "Task Meta",
  "description": "Schema for tasks/<task_id>/meta.json. Describes a single ONNX migration case for the kernel agent.",
  "type": "object",
  "required": [
    "task_id",
    "tier",
    "change_types",
    "base_model",
    "from",
    "to",
    "dtype"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^task_[0-9]{6}$"
    },
    "tier": {
      "type": "string",
      "enum": ["MVP-easy", "MVP-medium", "MVP-hard"]
    },
    "change_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "shape_param_change",
          "dtype_change",
          "activation_change",
          "norm_change",
          "attention_pattern_change",
          "op_fusion_change",
          "unknown"
        ]
      }
    },
    "base_model": {
      "type": "string",
      "description": "Logical model template name, e.g. ln_linear_gelu_linear"
    },
    "from": {
      "type": "object",
      "description": "Free-form key/value of pre-migration architecture parameters"
    },
    "to": {
      "type": "object",
      "description": "Free-form key/value of post-migration architecture parameters"
    },
    "dtype": {
      "type": "string",
      "enum": ["fp32", "fp16", "bf16", "int8"]
    },
    "device": {
      "type": "string",
      "default": "cuda"
    },
    "min_gpu_capability": {
      "type": "string",
      "examples": ["sm_70", "sm_80", "sm_90"]
    },
    "estimated_difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "expected_oracle_patch_ops": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20
    }
  },
  "additionalProperties": true
}
